NODE_ENV=production
PORT=4000

# Supabase PostgreSQL connection string.
# Find this in your Supabase project: Settings > Database > Connection string (URI).
DATABASE_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres"

# A strong random secret for signing JWT tokens. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-random-secret
JWT_EXPIRES_IN=8h

UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10

# Comma-separated list of allowed frontend origins for CORS.
# Set this to your Vercel deployment URL(s).
# Example: https://your-app.vercel.app,https://custom-domain.com
CORS_ORIGIN=https://your-app.vercel.app

# --- Placeholders for future integrations. Not called in the demo. ---
FBR_API_BASE_URL=
FBR_API_KEY=
WHATSAPP_API_BASE_URL=
WHATSAPP_API_TOKEN=
SMS_GATEWAY_API_KEY=
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=
CURRENCY_EXCHANGE_API_KEY=
AWS_S3_BUCKET=
AWS_S3_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
PAYMENT_GATEWAY_API_KEY=
