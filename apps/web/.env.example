# Base URL of the Express API, including the /api prefix. The typed client in
# src/lib/api-client.ts reads this via process.env.NEXT_PUBLIC_API_URL.
# NEXT_PUBLIC_* vars are inlined into the client bundle at build time (Next.js
# convention) so this value is not secret — never put real secrets in a
# NEXT_PUBLIC_ var.
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# Mirrors apps/api's MAX_UPLOAD_SIZE_MB (see apps/api/.env.example) so the
# shared FileUpload component (src/components/shared/file-upload.tsx) can
# pre-validate file size client-side before uploading. Keep these two values
# in sync manually — the frontend cannot read the backend's .env.
NEXT_PUBLIC_MAX_UPLOAD_SIZE_MB=10
